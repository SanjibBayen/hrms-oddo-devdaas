# ============================================================
# HRMS ENTERPRISE - Environment Variables
# ============================================================
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ──── NODE ────
NODE_ENV=development

# ──── SERVER ────
PORT=5000
HOST=0.0.0.0

# ──── MONGODB (Read/Write Split) ────
MONGODB_WRITE_URI=mongodb://admin:password@localhost:27017/hrms?authSource=admin
MONGODB_READ_URI=mongodb://admin:password@localhost:27018/hrms?authSource=admin

# ──── REDIS ────
REDIS_URL=redis://:redispassword@localhost:6379
REDIS_PASSWORD=redispassword

# ──── JWT ────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-secret-min-64-characters-long-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-min-64-characters-long-change-in-production
JWT_ACCESS_EXPIRY=5m
JWT_REFRESH_EXPIRY=7d

# ──── ENCRYPTION (AES-256-GCM) ────
# Generate key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate salt: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-in-production
ENCRYPTION_SALT=your-16-byte-hex-salt-change-in-production

# ──── CLOUDINARY ────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=hrms/profiles

# ──── SENDGRID (Email) ────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourcompany.com
SENDGRID_FROM_NAME=HRMS Enterprise

# ──── CORS ────
CORS_ORIGIN=http://localhost:5173

# ──── RATE LIMITING ────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ──── CLIENT ────
VITE_API_URL=http://localhost:5000/api/v1
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_APP_NAME=HRMS Enterprise